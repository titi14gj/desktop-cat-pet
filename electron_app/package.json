{
  "name": "desktop-cat-pet-windows",
  "version": "1.0.0",
  "description": "Windows desktop pet app for transparent GIF/WebM/PNG media.",
  "main": "src/main.js",
  "author": "titi14gj",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.titi14gj.desktopcatpet.windows",
    "productName": "桌面猫宠物",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "removePackageScripts": true,
    "electronLanguages": [
      "zh-CN"
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "DesktopCatPet-${version}-win-x64-portable.exe"
    }
  }
}
